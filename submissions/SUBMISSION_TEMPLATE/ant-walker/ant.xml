<mujoco model="ant">
  <compiler angle="degree" inertiafromgeom="true"/>
  <option integrator="RK4" timestep="0.01" gravity="0 0 -9.81"/>

  <default>
    <joint armature="1" damping="2" limited="true"/>
    <geom conaffinity="1" condim="3" density="5.0"
          friction="1.5 0.1 0.1" margin="0.01"/>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="150"/>
  </default>

  <asset>
    <texture builtin="checker" height="100" name="texplane"
             rgb1="0.25 0.35 0.25" rgb2="0.15 0.25 0.15"
             type="2d" width="100"/>
    <material name="MatPlane" reflectance="0.4" shininess="0.5"
              specular="0.5" texrepeat="40 40" texture="texplane"/>
    <material name="torso_mat"  rgba="0.3 0.5 0.8 1"/>
    <material name="leg_mat"    rgba="0.5 0.75 0.35 1"/>
    <material name="ankle_mat"  rgba="0.8 0.55 0.25 1"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="0 0 -1.3"
           directional="true" exponent="1" pos="0 0 3" specular=".2 .2 .2"/>
    <light cutoff="100" diffuse="0.5 0.5 0.5" dir="0 -1 -0.5"
           directional="true" pos="0 2 2"/>

    <!-- Ground -->
    <geom conaffinity="1" condim="3" material="MatPlane"
          name="floor" pos="0 0 0" size="50 50 0.1" type="plane"/>

    <!-- Obstacles -->
    <geom type="box" size="0.3 0.1 0.15" pos=" 2.0  1.0 0.15" rgba="0.7 0.3 0.3 1"/>
    <geom type="box" size="0.1 0.3 0.15" pos="-1.5  2.0 0.15" rgba="0.3 0.7 0.3 1"/>
    <geom type="box" size="0.2 0.2 0.20" pos=" 3.0 -1.5 0.20" rgba="0.3 0.3 0.7 1"/>
    <geom type="cylinder" size="0.15 0.2" pos="-2.5 -1.0 0.20" rgba="0.7 0.7 0.3 1"/>

    <!-- Waypoint 1 — blue -->
    <geom type="cylinder" size="0.5 0.01" pos="2.0 2.0 0.01"
          rgba="0.2 0.5 1.0 0.7" contype="0" conaffinity="0"/>
    <!-- Waypoint 2 — orange -->
    <geom type="cylinder" size="0.5 0.01" pos="4.0 0.0 0.01"
          rgba="1.0 0.5 0.1 0.7" contype="0" conaffinity="0"/>
    <!-- Final goal — gold -->
    <geom type="cylinder" size="0.5 0.01" pos="4.0 4.0 0.01"
          rgba="1.0 0.8 0.0 0.7" contype="0" conaffinity="0"/>

    <!--
      ANT torso spawns at z=0.75 so legs have room to reach the ground.

      LEG LAYOUT (viewed from above):
        FL (+x +y)  FR (-x +y)
             [torso]
        BL (+x -y)  BR (-x -y)

      Each upper-leg body is placed AT the hip socket position (outward from torso).
      The capsule then draws from (0,0,0) to a further outward+downward tip.
      The lower body sits at that tip; the ankle capsule goes straight down to the ground.
    -->
    <body name="torso" pos="0 0 0.75">
      <camera name="track" mode="trackcom" pos="0 -4 2"
              xyaxes="1 0 0 0 0.6 0.8"/>
      <camera name="top" mode="trackcom" pos="0 0 6"
              xyaxes="1 0 0 0 1 0"/>

      <geom name="torso_geom" type="sphere" size="0.25"
            material="torso_mat" mass="5"/>
      <joint armature="0" damping="0" limited="false"
             name="root" pos="0 0 0" type="free"/>

      <!-- ══════════════════════════════════════════
           FRONT-LEFT  (FL)  — hip socket at +x +y
           ══════════════════════════════════════════ -->
      <body name="fl_upper" pos="0.18 0.18 0.0">
        <!-- upper segment: from hip socket outward-and-slightly-down -->
        <geom type="capsule" fromto="0 0 0  0.22 0.22 -0.05"
              size="0.07" material="leg_mat"/>
        <!-- hip joint is at the socket; controls swing in horizontal plane -->
        <joint name="hip1" type="hinge" axis="0 0 1"
               range="-40 40" pos="0 0 0"/>
        <body name="fl_lower" pos="0.22 0.22 -0.05">
          <!-- ankle joint: bends the lower leg up/down -->
          <joint name="ankle1" type="hinge" axis="-1 1 0"
                 range="-70 30" pos="0 0 0"/>
          <!-- lower segment goes nearly straight down to touch the floor -->
          <geom type="capsule" fromto="0 0 0  0.05 0.05 -0.38"
                size="0.05" material="ankle_mat"/>
        </body>
      </body>

      <!-- ══════════════════════════════════════════
           FRONT-RIGHT (FR)  — hip socket at -x +y
           ══════════════════════════════════════════ -->
      <body name="fr_upper" pos="-0.18 0.18 0.0">
        <geom type="capsule" fromto="0 0 0  -0.22 0.22 -0.05"
              size="0.07" material="leg_mat"/>
        <joint name="hip2" type="hinge" axis="0 0 1"
               range="-40 40" pos="0 0 0"/>
        <body name="fr_lower" pos="-0.22 0.22 -0.05">
          <joint name="ankle2" type="hinge" axis="1 1 0"
                 range="-30 70" pos="0 0 0"/>
          <geom type="capsule" fromto="0 0 0  -0.05 0.05 -0.38"
                size="0.05" material="ankle_mat"/>
        </body>
      </body>

      <!-- ══════════════════════════════════════════
           BACK-LEFT  (BL)  — hip socket at +x -y
           ══════════════════════════════════════════ -->
      <body name="bl_upper" pos="0.18 -0.18 0.0">
        <geom type="capsule" fromto="0 0 0  0.22 -0.22 -0.05"
              size="0.07" material="leg_mat"/>
        <joint name="hip3" type="hinge" axis="0 0 1"
               range="-40 40" pos="0 0 0"/>
        <body name="bl_lower" pos="0.22 -0.22 -0.05">
          <joint name="ankle3" type="hinge" axis="-1 -1 0"
                 range="-30 70" pos="0 0 0"/>
          <geom type="capsule" fromto="0 0 0  0.05 -0.05 -0.38"
                size="0.05" material="ankle_mat"/>
        </body>
      </body>

      <!-- ══════════════════════════════════════════
           BACK-RIGHT (BR)  — hip socket at -x -y
           ══════════════════════════════════════════ -->
      <body name="br_upper" pos="-0.18 -0.18 0.0">
        <geom type="capsule" fromto="0 0 0  -0.22 -0.22 -0.05"
              size="0.07" material="leg_mat"/>
        <joint name="hip4" type="hinge" axis="0 0 1"
               range="-40 40" pos="0 0 0"/>
        <body name="br_lower" pos="-0.22 -0.22 -0.05">
          <joint name="ankle4" type="hinge" axis="1 -1 0"
                 range="-70 30" pos="0 0 0"/>
          <geom type="capsule" fromto="0 0 0  -0.05 -0.05 -0.38"
                size="0.05" material="ankle_mat"/>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <!-- order matches walk.py: hip1 ankle1 hip2 ankle2 hip3 ankle3 hip4 ankle4 -->
    <motor name="motor1" joint="hip1"/>
    <motor name="motor2" joint="ankle1"/>
    <motor name="motor3" joint="hip2"/>
    <motor name="motor4" joint="ankle2"/>
    <motor name="motor5" joint="hip3"/>
    <motor name="motor6" joint="ankle3"/>
    <motor name="motor7" joint="hip4"/>
    <motor name="motor8" joint="ankle4"/>
  </actuator>

</mujoco>